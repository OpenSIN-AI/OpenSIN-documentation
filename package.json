{
  "name": "opensin-docs",
  "version": "1.0.0",
  "description": "OpenSIN documentation site — docs.opensin.ai",
  "type": "module",
  "scripts": {
    "docs:dev": "vitepress dev",
    "docs:build": "node node_modules/vitepress/bin/vitepress.js build docs",
    "docs:preview": "vitepress preview",
    "build": "node node_modules/vitepress/bin/vitepress.js build docs",
    "deploy": "wrangler pages deploy docs/.vitepress/dist --project-name opensin-docs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "vitepress": "^1.5.0",
    "wrangler": "^4.81.1"
  }
}
